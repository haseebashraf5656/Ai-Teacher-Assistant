# ============================
# AI Teacher Assistant - Backend
# ============================

# Google Gemini API Key (get yours at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key (use a long random string in production)
SECRET_KEY=change-this-to-a-strong-random-secret

# Database URL (SQLite for dev, PostgreSQL for production)
# Development (default):
DATABASE_URL=sqlite:///./teacher_assistant.db
# Production (PostgreSQL example):
# DATABASE_URL=postgresql://user:password@localhost:5432/teacher_assistant
